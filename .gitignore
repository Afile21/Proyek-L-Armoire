# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- TAMBAHAN DARI TEMPLATE ---

# IDEs and editors (Biar settingan VS Code mu gak ikut ke-upload)
.vscode/
.idea/
*.sublime-*
*.sublime-project
*.sublime-workspace

# Database (Buat jaga-jaga kalau kamu pakai database lokal)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3